{
  "name": "@transparencia/ingestao-cvm",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "discover:ts": "tsx src/run-discover.ts",
    "cadastro:ts": "tsx src/run-cadastro.ts",
    "fip:ts": "tsx src/run-fip.ts",
    "cda:ts": "NODE_OPTIONS=--max-old-space-size=4096 tsx src/run-cda.ts",
    "oferta:ts": "NODE_OPTIONS=--max-old-space-size=4096 tsx src/run-oferta.ts",
    "receita:ts": "NODE_OPTIONS=--max-old-space-size=4096 tsx src/run-receita.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0"
  }
}
