<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.thebrinsider.cda-mensal</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/luizlessa/transparencia-federal/scripts/cda-cron.sh</string>
  </array>

  <!-- Dia 10 de cada mês às 10:00 BRT (CDA sai ~5 dias após fim do mês) -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Day</key>
    <integer>10</integer>
    <key>Hour</key>
    <integer>10</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>RunAtLoad</key>
  <false/>

  <key>StandardOutPath</key>
  <string>/Users/luizlessa/Library/Logs/cda-cron.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/luizlessa/Library/Logs/cda-cron-error.log</string>

  <key>ThrottleInterval</key>
  <integer>86400</integer>
</dict>
</plist>
