# Transparência Federal v3 — variáveis de ambiente
# Copiar para .env e preencher; nunca commitar .env

# Supabase (banco e API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Portal da Transparência (ingestão)
PORTAL_TRANSPARENCIA_API_KEY=

# Opcional: URL base da API do Portal (se diferente do default)
# PORTAL_TRANSPARENCIA_BASE_URL=

# Frontend (packages/web): URL base da API pública. Se vazio, o front usa /api no mesmo origin.
# NEXT_PUBLIC_API_URL=
